	partition 材料_契約単価_月次 = calculated
		mode: import
		source = ```

				VAR __Rev0 =
				    FILTER (
				        'TB_材料仕入先単価情報',
				        NOT ISBLANK ( 'TB_材料仕入先単価情報'[F_材料番号] )
				            && NOT ISBLANK ( 'TB_材料仕入先単価情報'[F_開始日] )
				            && NOT ISBLANK ( 'TB_材料仕入先単価情報'[F_契約単価] )
				    )

				VAR __Rev1 =
				    SELECTCOLUMNS (
				        __Rev0,
				        "__材料番号",
				            TRIM (
				                SUBSTITUTE (
				                    'TB_材料仕入先単価情報'[F_材料番号],
				                    UNICHAR ( 12288 ),
				                    " "
				                )
				            ) & "",
				        "__仕入先", 'TB_材料仕入先単価情報'[F_仕入先番号] & "",
				        "__開始月",
				            EOMONTH ( 'TB_材料仕入先単価情報'[F_開始日], -1 ) + 1,
				        "__単価", 'TB_材料仕入先単価情報'[F_契約単価]
				    )

				VAR __MatSet =
				    FILTER (
				        DISTINCT (
				            SELECTCOLUMNS (
				                '材料情報',
				                "__材料番号",
				                    TRIM (
				                        SUBSTITUTE (
				                            '材料情報'[F_材料番号],
				                            UNICHAR ( 12288 ),
				                            " "
				                        )
				                    ) & ""
				            )
				        ),
				        [__材料番号] <> ""
				    )

				VAR __Rev =
				    NATURALINNERJOIN ( __Rev1, __MatSet )

				VAR __MaxM =
				    EOMONTH ( TODAY (), -1 )

				VAR __MinM =
				    MINX ( __Rev, [__開始月] )

				VAR __Combo =
				    GROUPBY (
				        __Rev,
				        [__材料番号],
				        [__仕入先],
				        "__初月", MINX ( CURRENTGROUP (), [__開始月] )
				    )

				VAR __AllMonths =
				    SELECTCOLUMNS (
				        GENERATESERIES ( 0, DATEDIFF ( __MinM, __MaxM, MONTH ), 1 ),
				        "__月", EDATE ( __MinM, [Value] )
				    )

				VAR __ComboMonth =
				    FILTER (
				        CROSSJOIN ( __Combo, __AllMonths ),
				        [__月] >= [__初月]
				    )

				VAR __ComboPrice =
				    ADDCOLUMNS (
				        __ComboMonth,
				        "__適用単価",
				            VAR k1 = [__材料番号]
				            VAR k2 = [__仕入先]
				            VAR m  = [__月]
				            VAR lastRev =
				                MAXX (
				                    FILTER (
				                        __Rev,
				                        [__材料番号] = k1
				                            && [__仕入先] = k2
				                            && [__開始月] <= m
				                    ),
				                    [__開始月]
				                )
				            RETURN
				                MAXX (
				                    FILTER (
				                        __Rev,
				                        [__材料番号] = k1
				                            && [__仕入先] = k2
				                            && [__開始月] = lastRev
				                    ),
				                    [__単価]
				                )
				    )

				VAR __ByMat =
				    GROUPBY (
				        __ComboPrice,
				        [__材料番号],
				        [__月],
				        "__契約単価", AVERAGEX ( CURRENTGROUP (), [__適用単価] )
				    )

				VAR __WithPrev =
				    ADDCOLUMNS (
				        __ByMat,
				        "__前月単価",
				            VAR k = [__材料番号]
				            VAR pm = EDATE ( [__月], -1 )
				            RETURN
				                MAXX (
				                    FILTER ( __ByMat, [__材料番号] = k && [__月] = pm ),
				                    [__契約単価]
				                )
				    )

				VAR __EvQ0 =
				    FILTER (
				        'TB_仕入実績情報',
				        NOT ISBLANK ( 'TB_仕入実績情報'[F_品目番号] )
				            && NOT ISBLANK ( 'TB_仕入実績情報'[F_仕入日] )
				            && 'TB_仕入実績情報'[F_仕入数] > 0
				    )

				VAR __EvQ1 =
				    SELECTCOLUMNS (
				        __EvQ0,
				        "__材料番号",
				            TRIM (
				                SUBSTITUTE (
				                    'TB_仕入実績情報'[F_品目番号],
				                    UNICHAR ( 12288 ),
				                    " "
				                )
				            ) & "",
				        "__月",
				            EOMONTH ( DATEVALUE ( 'TB_仕入実績情報'[F_仕入日] ), -1 ) + 1,
				        "__数", 'TB_仕入実績情報'[F_仕入数]
				    )

				VAR __EvQM =
				    NATURALINNERJOIN ( __EvQ1, __MatSet )

				VAR __Q =
				    GROUPBY (
				        __EvQM,
				        [__材料番号],
				        [__月],
				        "__月数計", SUMX ( CURRENTGROUP (), [__数] )
				    )

				VAR __QShift =
				    SELECTCOLUMNS (
				        CROSSJOIN (
				            __Q,
				            SELECTCOLUMNS ( GENERATESERIES ( 0, 11, 1 ), "__k", [Value] )
				        ),
				        "__材料番号", [__材料番号],
				        "__基準月",   EDATE ( [__月], [__k] ),
				        "__数c",      [__月数計]
				    )

				VAR __QAgg =
				    GROUPBY (
				        __QShift,
				        [__材料番号],
				        [__基準月],
				        "__稼働量", SUMX ( CURRENTGROUP (), [__数c] )
				    )

				VAR __Final0 =
				    NATURALLEFTOUTERJOIN (
				        __WithPrev,
				        SELECTCOLUMNS ( __QAgg, "__材料番号", [__材料番号], "__月", [__基準月], "__稼働量", [__稼働量] )
				    )

				VAR __Final =
				    ADDCOLUMNS (
				        __Final0,
				        "__値上げ額",
				            IF (
				                NOT ISBLANK ( [__前月単価] ),
				                [__契約単価] - [__前月単価]
				            )
				    )

				VAR __Map0 =
				    SELECTCOLUMNS (
				        '材料情報',
				        "__材料番号",
				            TRIM (
				                SUBSTITUTE (
				                    '材料情報'[F_材料番号],
				                    UNICHAR ( 12288 ),
				                    " "
				                )
				            ) & "",
				        "__在k", '材料情報'[F_在庫材料番号] & ""
				    )

				VAR __Map =
				    GROUPBY (
				        __Map0,
				        [__材料番号],
				        "__在庫番号", MAXX ( CURRENTGROUP (), [__在k] )
				    )

				VAR __J2 =
				    NATURALLEFTOUTERJOIN ( __Final, __Map )

				RETURN
				    SELECTCOLUMNS (
				        __J2,
				        "F_在庫材料番号", [__在庫番号],
				        "F_材料番号",     [__材料番号],
				        "F_開始月",       [__月],
				        "契約単価",       [__契約単価],
				        "契約単価_前月契約単価",   [__前月単価],
				        "契約単価_値上げ額",       [__値上げ額],
				        "契約単価_値上げ率",       DIVIDE ( [__値上げ額], [__前月単価] ),
				        "契約単価_年間予測影響額", [__値上げ額] * [__稼働量],
				        "契約単価_年間予測影響額_値上げのみ",
				            IF ( [__値上げ額] > 0, [__値上げ額] * [__稼働量] ),
				        "契約単価_年間予測影響額_値下げのみ",
				            IF ( [__値上げ額] < 0, [__値上げ額] * [__稼働量] ),
				        "契約単価_直近12か月稼働量", [__稼働量]
				    )

				```

	annotation PBI_Id = e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0

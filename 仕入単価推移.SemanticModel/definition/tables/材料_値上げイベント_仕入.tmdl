	partition 材料_値上げイベント_仕入 = calculated
		mode: import
		source =
				
				VAR __Ev0 =
				    FILTER (
				        '材料_仕入単価履歴',
				        NOT ISBLANK ( '材料_仕入単価履歴'[値上げ額] )
				            && '材料_仕入単価履歴'[値上げ額] <> 0
				    )
				
				VAR __EvWithQty =
				    ADDCOLUMNS (
				        __Ev0,
				
				        "月次キー",
				            FORMAT ( [F_開始月], "yyyymmdd" ) & "|"
				                & [F_材料番号] & "|"
				                & [F_仕入先番号],
				
				        "直近12か月稼働量",
				            LOOKUPVALUE (
				                '材料_年平均稼働量_仕入'[直近12か月稼働量],
				                '材料_年平均稼働量_仕入'[F_材料番号], [F_材料番号]
				            )
				    )
				
				RETURN
				    ADDCOLUMNS (
				        __EvWithQty,
				
				        "値上げ率",
				            DIVIDE ( [値上げ額], [前回単価] ),
				
				        "改定方向",
				            IF ( [値上げ額] > 0, "値上げ", "値下げ" ),
				
				        "絶対値上げ額",
				            ABS ( [値上げ額] ),
				
				        "外れ値フラグ",
				            IF ( ABS ( [値上げ額] ) >= 50000, 1, 0 ),
				
				        "年間予測影響額",
				            [値上げ額] * [直近12か月稼働量],
				
				        "値上げ額_値上げのみ",
				            IF ( [値上げ額] > 0, [値上げ額], BLANK () ),
				
				        "値下げ額_値下げのみ",
				            IF ( [値上げ額] < 0, [値上げ額], BLANK () ),
				
				        "値下げ額_値下げのみ_絶対値",
				            IF ( [値上げ額] < 0, ABS ( [値上げ額] ), BLANK () ),
				
				        "年間予測影響額_値上げのみ",
				            IF ( [値上げ額] > 0, [値上げ額] * [直近12か月稼働量], BLANK () ),
				
				        "年間予測影響額_値下げのみ",
				            IF ( [値上げ額] < 0, [値上げ額] * [直近12か月稼働量], BLANK () ),
				
				        "年間予測影響額_値下げのみ_絶対値",
				            IF ( [値上げ額] < 0, ABS ( [値上げ額] * [直近12か月稼働量] ), BLANK () )
				    )

	annotation PBI_Id = a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5


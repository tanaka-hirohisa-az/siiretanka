table 材料_値上げイベント_仕入
	lineageTag: a0b1c2d3-e4f5-4a67-8b9c-0d1e2f3a4b5c

	measure 月別_単価改定額ABS_合計_材料_仕入 = ```
			
			SUMX (
			    '材料_値上げイベント_仕入',
			    ABS ( '材料_値上げイベント_仕入'[値上げ額] )
			)
			
			```
		lineageTag: a1b2c3d4-e5f6-4a78-9b0c-1d2e3f4a5b6c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 1件あたり_単価改定額ABS_平均_材料_仕入 = ```
			
			AVERAGEX (
			    '材料_値上げイベント_仕入',
			    ABS ( '材料_値上げイベント_仕入'[値上げ額] )
			)
			
			```
		lineageTag: b2c3d4e5-f6a7-4b89-0c1d-2e3f4a5b6c7d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 月別_値上げ額_合計_材料_仕入 =
			
			CALCULATE (
			    SUM ( '材料_値上げイベント_仕入'[値上げ額] ),
			    '材料_値上げイベント_仕入'[値上げ額] > 0
			)
		lineageTag: c3d4e5f6-a7b8-4c90-1d2e-3f4a5b6c7d8e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 月別_値下げ額_合計_材料_仕入 =
			
			CALCULATE (
			    SUM ( '材料_値上げイベント_仕入'[値上げ額] ),
			    '材料_値上げイベント_仕入'[値上げ額] < 0
			)
		lineageTag: d4e5f6a7-b8c9-4d01-2e3f-4a5b6c7d8e9f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 1件あたり_値上げ額_平均_材料_仕入 =
			
			AVERAGEX (
			    FILTER ( '材料_値上げイベント_仕入', '材料_値上げイベント_仕入'[値上げ額] > 0 ),
			    '材料_値上げイベント_仕入'[値上げ額]
			)
		lineageTag: e5f6a7b8-c9d0-4e12-3f4a-5b6c7d8e9f0a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 1件あたり_値下げ額_平均_材料_仕入 =
			
			AVERAGEX (
			    FILTER ( '材料_値上げイベント_仕入', '材料_値上げイベント_仕入'[値上げ額] < 0 ),
			    '材料_値上げイベント_仕入'[値上げ額]
			)
		lineageTag: f6a7b8c9-d0e1-4f23-4a5b-6c7d8e9f0a1b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 月別_純増減額合計_材料_明細_仕入 =
			
			SUMX (
			    VALUES ( '材料_値上げイベント_仕入'[月次キー] ),
			    CALCULATE (
			        MAX ( '材料_月別純増減_仕入'[純増減額] ),
			        TREATAS (
			            VALUES ( '材料_値上げイベント_仕入'[月次キー] ),
			            '材料_月別純増減_仕入'[月次キー]
			        )
			    )
			)
		lineageTag: a7b8c9d0-e1f2-4034-5b6c-7d8e9f0a1b2c

	measure 月別_純値上げ額合計_材料_明細_仕入 =
			
			SUMX (
			    VALUES ( '材料_値上げイベント_仕入'[月次キー] ),
			    CALCULATE (
			        MAX ( '材料_月別純増減_仕入'[月別_純値上げ額合計_材料] ),
			        TREATAS (
			            VALUES ( '材料_値上げイベント_仕入'[月次キー] ),
			            '材料_月別純増減_仕入'[月次キー]
			        )
			    )
			)
		lineageTag: b8c9d0e1-f2a3-4145-6c7d-8e9f0a1b2c3d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 月別_純値下げ額合計_材料_明細_仕入 =
			
			SUMX (
			    VALUES ( '材料_値上げイベント_仕入'[月次キー] ),
			    CALCULATE (
			        MAX ( '材料_月別純増減_仕入'[月別_純値下げ額合計_材料] ),
			        TREATAS (
			            VALUES ( '材料_値上げイベント_仕入'[月次キー] ),
			            '材料_月別純増減_仕入'[月次キー]
			        )
			    )
			)
		lineageTag: c9d0e1f2-a3b4-4256-7d8e-9f0a1b2c3d4e

		annotation PBI_FormatHint = {"isGeneralNumber":true}


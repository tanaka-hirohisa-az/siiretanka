	partition 明細_材料在庫_稼働 = calculated
		mode: import
		source = ```
				
				VAR __Base =
				    FILTER (
				        'TB_材料在庫明細情報',
				        'TB_材料在庫明細情報'[F_在庫場所] = "S3000"
				            || 'TB_材料在庫明細情報'[F_在庫場所] = "S4000"
				    )
				
				/* Base内（S3000/S4000）の材料別 在庫数量合計を1回だけ作る（※ALL禁止） */
				VAR __StockByMat =
				    GROUPBY (
				        ADDCOLUMNS (
				            __Base,
				            "__k",
				                TRIM (
				                    SUBSTITUTE ( 'TB_材料在庫明細情報'[F_在庫材料番号], UNICHAR ( 12288 ), " " )
				                )
				        ),
				        [__k],
				        "__stock",
				            SUMX ( CURRENTGROUP (), 'TB_材料在庫明細情報'[F_数量] )
				    )
				
				/* Step1：最終稼働日（入出庫区分=02 の最新入出庫日）と最終受入日（手配残） */
				VAR __Step1 =
				    ADDCOLUMNS (
				        __Base,
				
				        "最終稼働日",
				            VAR k =
				                TRIM (
				                    SUBSTITUTE ( 'TB_材料在庫明細情報'[F_在庫材料番号], UNICHAR ( 12288 ), " " )
				                )
				            RETURN
				                CALCULATE (
				                    MAX ( 'TB_材料入出庫実績情報'[F_入出庫日] ),
				                    FILTER (
				                        ALL ( 'TB_材料入出庫実績情報' ),
				                        'TB_材料入出庫実績情報'[F_入出庫区分] = "02"
				                            && TRIM (
				                                SUBSTITUTE ( 'TB_材料入出庫実績情報'[F_品目番号], UNICHAR ( 12288 ), " " )
				                            ) = k
				                    )
				                ),
				
				        "最終受入日",
				            VAR k =
				                TRIM (
				                    SUBSTITUTE ( 'TB_材料在庫明細情報'[F_在庫材料番号], UNICHAR ( 12288 ), " " )
				                )
				            RETURN
				                CALCULATE (
				                    MAX ( 'TB_材料手配残'[F_最終受入日] ),
				                    FILTER (
				                        ALL ( 'TB_材料手配残' ),
				                        TRIM (
				                            SUBSTITUTE ( 'TB_材料手配残'[F_材料番号], UNICHAR ( 12288 ), " " )
				                        ) = k
				                    )
				                )
				    )
				
				/* Step2：稼働区分（最終稼働日のみ）＋単価・仕入先（開始日最大） */
				VAR __Step2 =
				    ADDCOLUMNS (
				        __Step1,
				
				        "稼働区分",
				            VAR d_work = [最終稼働日]
				            VAR diff =
				                IF ( ISBLANK ( d_work ), BLANK (), INT ( TODAY () ) - INT ( d_work ) )
				            RETURN
				                IF (
				                    ISBLANK ( d_work ),
				                    BLANK (),
				                    SWITCH (
				                        TRUE (),
				                        diff <= 365,  "1年以内",
				                        diff <= 730,  "2年以内",
				                        diff <= 1825, "5年以内",
				                        "5年以上"
				                    )
				                ),
				
				        "稼働区分Sort",
				            VAR d_work = [最終稼働日]
				            VAR diff =
				                IF ( ISBLANK ( d_work ), BLANK (), INT ( TODAY () ) - INT ( d_work ) )
				            RETURN
				                IF (
				                    ISBLANK ( d_work ),
				                    BLANK (),
				                    SWITCH (
				                        TRUE (),
				                        diff <= 365,  1,
				                        diff <= 730,  2,
				                        diff <= 1825, 3,
				                        4
				                    )
				                ),
				
				        "R_仕入先番号",
				            VAR k =
				                TRIM (
				                    SUBSTITUTE ( 'TB_材料在庫明細情報'[F_在庫材料番号], UNICHAR ( 12288 ), " " )
				                )
				            VAR tLatest =
				                TOPN (
				                    1,
				                    FILTER (
				                        ALL ( 'TB_材料仕入先単価情報' ),
				                        TRIM (
				                            SUBSTITUTE ( 'TB_材料仕入先単価情報'[F_材料番号], UNICHAR ( 12288 ), " " )
				                        ) = k
				                            && NOT ISBLANK ( 'TB_材料仕入先単価情報'[F_開始日] )
				                    ),
				                    'TB_材料仕入先単価情報'[F_開始日], DESC
				                )
				            RETURN
				                MAXX ( tLatest, 'TB_材料仕入先単価情報'[F_仕入先番号] ),
				
				        "F_契約単価",
				            VAR k =
				                TRIM (
				                    SUBSTITUTE ( 'TB_材料在庫明細情報'[F_在庫材料番号], UNICHAR ( 12288 ), " " )
				                )
				            VAR tLatest =
				                TOPN (
				                    1,
				                    FILTER (
				                        ALL ( 'TB_材料仕入先単価情報' ),
				                        TRIM (
				                            SUBSTITUTE ( 'TB_材料仕入先単価情報'[F_材料番号], UNICHAR ( 12288 ), " " )
				                        ) = k
				                            && NOT ISBLANK ( 'TB_材料仕入先単価情報'[F_開始日] )
				                    ),
				                    'TB_材料仕入先単価情報'[F_開始日], DESC
				                )
				            RETURN
				                MAXX ( tLatest, 'TB_材料仕入先単価情報'[F_契約単価] ),
				
				        "直近単価日付",
				            VAR k =
				                TRIM (
				                    SUBSTITUTE ( 'TB_材料在庫明細情報'[F_在庫材料番号], UNICHAR ( 12288 ), " " )
				                )
				            VAR tLatest =
				                TOPN (
				                    1,
				                    FILTER (
				                        ALL ( 'TB_材料仕入先単価情報' ),
				                        TRIM (
				                            SUBSTITUTE ( 'TB_材料仕入先単価情報'[F_材料番号], UNICHAR ( 12288 ), " " )
				                        ) = k
				                            && NOT ISBLANK ( 'TB_材料仕入先単価情報'[F_開始日] )
				                    ),
				                    'TB_材料仕入先単価情報'[F_開始日], DESC
				                )
				            RETURN
				                MAXX ( tLatest, 'TB_材料仕入先単価情報'[F_開始日] )
				    )
				
				/* Step3：在庫金額＋仕入先略称＋年平均稼働量＋在庫消化予測年数＋予測区分（stockは__StockByMat参照） */
				VAR __Step3 =
				    ADDCOLUMNS (
				        __Step2,
				
				        "在庫金額",
				            VAR qty   = 'TB_材料在庫明細情報'[F_数量]
				            VAR price = [F_契約単価]
				            RETURN
				                IF ( ISBLANK ( qty ) || ISBLANK ( price ), BLANK (), qty * price ),
				
				        "F_仕入先略称",
				            LOOKUPVALUE (
				                'TB_仕入先情報'[F_仕入先略称],
				                'TB_仕入先情報'[F_仕入先番号], [R_仕入先番号]
				            ),
				
				        "年平均稼働量",
				            VAR k =
				                TRIM (
				                    SUBSTITUTE ( 'TB_材料在庫明細情報'[F_在庫材料番号], UNICHAR ( 12288 ), " " )
				                )
				            RETURN
				                LOOKUPVALUE (
				                    '材料_年平均稼働量'[過去5年平均年間稼働量],
				                    '材料_年平均稼働量'[F_材料番号], k
				                ),
				
				        "在庫消化予測年数",
				            VAR k =
				                TRIM (
				                    SUBSTITUTE ( 'TB_材料在庫明細情報'[F_在庫材料番号], UNICHAR ( 12288 ), " " )
				                )
				            VAR stock =
				                MAXX ( FILTER ( __StockByMat, [__k] = k ), [__stock] )
				            VAR avgY =
				                LOOKUPVALUE (
				                    '材料_年平均稼働量'[過去5年平均年間稼働量],
				                    '材料_年平均稼働量'[F_材料番号], k
				                )
				            RETURN
				                IF (
				                    ISBLANK ( avgY ) || avgY <= 0,
				                    1 / 0,
				                    DIVIDE ( COALESCE ( stock, 0 ), avgY )
				                ),
				
				        "予測区分",
				            VAR k =
				                TRIM (
				                    SUBSTITUTE ( 'TB_材料在庫明細情報'[F_在庫材料番号], UNICHAR ( 12288 ), " " )
				                )
				            VAR stock2 =
				                MAXX ( FILTER ( __StockByMat, [__k] = k ), [__stock] )
				            VAR avgY2 =
				                LOOKUPVALUE (
				                    '材料_年平均稼働量'[過去5年平均年間稼働量],
				                    '材料_年平均稼働量'[F_材料番号], k
				                )
				            VAR y2 =
				                IF (
				                    ISBLANK ( avgY2 ) || avgY2 <= 0,
				                    1 / 0,
				                    DIVIDE ( COALESCE ( stock2, 0 ), avgY2 )
				                )
				            RETURN
				                IF (
				                    ISBLANK ( y2 ),
				                    BLANK (),
				                    IF (
				                        ISBLANK ( avgY2 ) || avgY2 <= 0,
				                        "5年以上",
				                        SWITCH (
				                            TRUE (),
				                            y2 <= 1, "1年以内",
				                            y2 <= 2, "2年以内",
				                            y2 <= 5, "5年以内",
				                            "5年以上"
				                        )
				                    )
				                ),
				
				        "予測区分Sort",
				            VAR k =
				                TRIM (
				                    SUBSTITUTE ( 'TB_材料在庫明細情報'[F_在庫材料番号], UNICHAR ( 12288 ), " " )
				                )
				            VAR stock3 =
				                MAXX ( FILTER ( __StockByMat, [__k] = k ), [__stock] )
				            VAR avgY3 =
				                LOOKUPVALUE (
				                    '材料_年平均稼働量'[過去5年平均年間稼働量],
				                    '材料_年平均稼働量'[F_材料番号], k
				                )
				            VAR y3 =
				                IF (
				                    ISBLANK ( avgY3 ) || avgY3 <= 0,
				                    1 / 0,
				                    DIVIDE ( COALESCE ( stock3, 0 ), avgY3 )
				                )
				            RETURN
				                IF (
				                    ISBLANK ( y3 ),
				                    BLANK (),
				                    IF (
				                        ISBLANK ( avgY3 ) || avgY3 <= 0,
				                        4,
				                        SWITCH (
				                            TRUE (),
				                            y3 <= 1, 1,
				                            y3 <= 2, 2,
				                            y3 <= 5, 3,
				                            4
				                        )
				                    )
				                )
				    )
				
				RETURN
				    __Step3
				

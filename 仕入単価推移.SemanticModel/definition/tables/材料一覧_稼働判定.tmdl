	partition 材料一覧_稼働判定 = calculated
		mode: import
		source = ```
				
				/* ベース：在庫場所 S3000/S4000 の在庫材料番号（正規化キーでユニーク） */
				VAR __BaseItems =
				    DISTINCT (
				        SELECTCOLUMNS (
				            FILTER (
				                'TB_材料在庫明細情報',
				                'TB_材料在庫明細情報'[F_在庫場所] = "S3000"
				                    || 'TB_材料在庫明細情報'[F_在庫場所] = "S4000"
				            ),
				            "F_在庫材料番号",
				                TRIM (
				                    SUBSTITUTE ( 'TB_材料在庫明細情報'[F_在庫材料番号], UNICHAR ( 12288 ), " " )
				                )
				        )
				    )
				
				/* 1段目：最終稼働日（入出庫区分=02 の最新入出庫日）と最終受入日（手配残） */
				VAR __WithDates =
				    ADDCOLUMNS (
				        __BaseItems,
				
				        "最終稼働日",
				            VAR k = [F_在庫材料番号]
				            RETURN
				                CALCULATE (
				                    MAX ( 'TB_材料入出庫実績情報'[F_入出庫日] ),
				                    FILTER (
				                        ALL ( 'TB_材料入出庫実績情報' ),
				                        'TB_材料入出庫実績情報'[F_入出庫区分] = "02"
				                            && TRIM (
				                                SUBSTITUTE ( 'TB_材料入出庫実績情報'[F_品目番号], UNICHAR ( 12288 ), " " )
				                            ) = k
				                    )
				                ),
				
				        "最終受入日",
				            VAR k = [F_在庫材料番号]
				            RETURN
				                CALCULATE (
				                    MAX ( 'TB_材料手配残'[F_最終受入日] ),
				                    FILTER (
				                        ALL ( 'TB_材料手配残' ),
				                        TRIM (
				                            SUBSTITUTE ( 'TB_材料手配残'[F_材料番号], UNICHAR ( 12288 ), " " )
				                        ) = k
				                    )
				                )
				    )
				
				/* 2段目：稼働区分付与（元ロジック完全一致） */
				RETURN
				    ADDCOLUMNS (
				        __WithDates,
				
				        "稼働区分",
				            VAR d_work = [最終稼働日]
				            VAR d_recv = [最終受入日]
				            VAR d = IF ( NOT ISBLANK ( d_work ), d_work, d_recv )
				            VAR diff = IF ( ISBLANK ( d ), BLANK (), INT ( TODAY () ) - INT ( d ) )
				            RETURN
				                IF (
				                    ISBLANK ( d ),
				                    BLANK (),
				                    SWITCH (
				                        TRUE (),
				                        diff <= 365,  "1年以内",
				                        diff <= 730,  "2年以内",
				                        diff <= 1825, "5年以内",
				                        "5年以上"
				                    )
				                ),
				
				        "稼働区分Sort",
				            VAR d_work = [最終稼働日]
				            VAR d_recv = [最終受入日]
				            VAR d = IF ( NOT ISBLANK ( d_work ), d_work, d_recv )
				            VAR diff = IF ( ISBLANK ( d ), BLANK (), INT ( TODAY () ) - INT ( d ) )
				            RETURN
				                IF (
				                    ISBLANK ( d ),
				                    BLANK (),
				                    SWITCH (
				                        TRUE (),
				                        diff <= 365,  1,
				                        diff <= 730,  2,
				                        diff <= 1825, 3,
				                        4
				                    )
				                )
				    )
				
				```

	annotation PBI_Id = 4c235e892f3348db8aa336602f470473


	partition 材料_単価比較_月次 = calculated
		mode: import
		source = ```

				VAR __Base =
				    SELECTCOLUMNS (
				        '材料_加重平均単価_月次',
				        "F_在庫材料番号", [F_在庫材料番号],
				        "F_材料番号", [F_材料番号],
				        "F_開始月", [F_開始月],
				        "加重平均単価", [加重平均単価],
				        "前回加重平均単価", [前回加重平均単価],
				        "値上げ額", [値上げ額],
				        "値上げ率", [値上げ率],
				        "月内仕入数", [月内仕入数],
				        "月内仕入金額", [月内仕入金額],
				        "年間予測影響額", [年間予測影響額],
				        "年間予測影響額_値上げのみ", [年間予測影響額_値上げのみ],
				        "年間予測影響額_値下げのみ", [年間予測影響額_値下げのみ]
				    )

				RETURN
				    ADDCOLUMNS (
				        __Base,
				        "契約単価",
				            LOOKUPVALUE (
				                '材料_契約単価_月次'[契約単価],
				                '材料_契約単価_月次'[F_材料番号], [F_材料番号],
				                '材料_契約単価_月次'[F_開始月], [F_開始月]
				            ),
				        "契約単価_前月契約単価",
				            LOOKUPVALUE (
				                '材料_契約単価_月次'[契約単価_前月契約単価],
				                '材料_契約単価_月次'[F_材料番号], [F_材料番号],
				                '材料_契約単価_月次'[F_開始月], [F_開始月]
				            ),
				        "契約単価_値上げ額",
				            LOOKUPVALUE (
				                '材料_契約単価_月次'[契約単価_値上げ額],
				                '材料_契約単価_月次'[F_材料番号], [F_材料番号],
				                '材料_契約単価_月次'[F_開始月], [F_開始月]
				            ),
				        "契約単価_値上げ率",
				            LOOKUPVALUE (
				                '材料_契約単価_月次'[契約単価_値上げ率],
				                '材料_契約単価_月次'[F_材料番号], [F_材料番号],
				                '材料_契約単価_月次'[F_開始月], [F_開始月]
				            ),
				        "契約単価_年間予測影響額",
				            LOOKUPVALUE (
				                '材料_契約単価_月次'[契約単価_年間予測影響額],
				                '材料_契約単価_月次'[F_材料番号], [F_材料番号],
				                '材料_契約単価_月次'[F_開始月], [F_開始月]
				            ),
				        "契約単価_年間予測影響額_値上げのみ",
				            LOOKUPVALUE (
				                '材料_契約単価_月次'[契約単価_年間予測影響額_値上げのみ],
				                '材料_契約単価_月次'[F_材料番号], [F_材料番号],
				                '材料_契約単価_月次'[F_開始月], [F_開始月]
				            ),
				        "契約単価_年間予測影響額_値下げのみ",
				            LOOKUPVALUE (
				                '材料_契約単価_月次'[契約単価_年間予測影響額_値下げのみ],
				                '材料_契約単価_月次'[F_材料番号], [F_材料番号],
				                '材料_契約単価_月次'[F_開始月], [F_開始月]
				            )
				    )

				```

	annotation PBI_Id = f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6

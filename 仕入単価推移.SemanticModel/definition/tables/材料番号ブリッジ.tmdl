table 材料番号ブリッジ
	lineageTag: f8a9b0c1-d2e3-4f45-6a7b-8c9d4e5f6a7b

	column F_材料番号
		lineageTag: a9b0c1d2-e3f4-4056-7b8c-9d0e5f6a7b8c
		summarizeBy: none
		isNameInferred
		sourceColumn: [F_材料番号]

		annotation SummarizationSetBy = Automatic

	partition 材料番号ブリッジ = calculated
		mode: import
		source = ```

				FILTER (
				    DISTINCT (
				        SELECTCOLUMNS (
				            '材料情報',
				            "F_材料番号",
				                TRIM (
				                    SUBSTITUTE (
				                        '材料情報'[F_材料番号],
				                        UNICHAR ( 12288 ),
				                        " "
				                    )
				                ) & ""
				        )
				    ),
				    [F_材料番号] <> ""
				)

				```

	annotation PBI_Id = f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3

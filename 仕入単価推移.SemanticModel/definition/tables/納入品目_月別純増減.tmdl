	partition 納入品目_月別純増減 = calculated
		mode: import
		source =
				
				VAR __Base =
				    SUMMARIZE (
				        '納入品目_仕入単価履歴',
				        '納入品目_仕入単価履歴'[F_開始月],
				        '納入品目_仕入単価履歴'[F_納入品目番号],
				        '納入品目_仕入単価履歴'[F_仕入先番号]
				    )
				RETURN
				    FILTER (
				        ADDCOLUMNS (
				            __Base,
				
				            "F_仕入先略称",
				                LOOKUPVALUE (
				                    'TB_仕入先情報'[F_仕入先略称],
				                    'TB_仕入先情報'[F_仕入先番号], [F_仕入先番号]
				                ),
				
				            "月内イベント件数",
				                VAR m  = [F_開始月]
				                VAR ms = m
				                VAR me = EOMONTH ( m, 0 )
				                VAR k1 = [F_納入品目番号]
				                VAR k2 = [F_仕入先番号]
				                RETURN
				                    COUNTROWS (
				                        FILTER (
				                            ALL ( '納入品目_仕入単価履歴' ),
				                            '納入品目_仕入単価履歴'[F_納入品目番号] = k1
				                                && '納入品目_仕入単価履歴'[F_仕入先番号] = k2
				                                && '納入品目_仕入単価履歴'[F_開始日] >= ms
				                                && '納入品目_仕入単価履歴'[F_開始日] <= me
				                        )
				                    ),
				
				            "月内最終開始日",
				                VAR m  = [F_開始月]
				                VAR ms = m
				                VAR me = EOMONTH ( m, 0 )
				                VAR k1 = [F_納入品目番号]
				                VAR k2 = [F_仕入先番号]
				                RETURN
				                    MAXX (
				                        FILTER (
				                            ALL ( '納入品目_仕入単価履歴' ),
				                            '納入品目_仕入単価履歴'[F_納入品目番号] = k1
				                                && '納入品目_仕入単価履歴'[F_仕入先番号] = k2
				                                && '納入品目_仕入単価履歴'[F_開始日] >= ms
				                                && '納入品目_仕入単価履歴'[F_開始日] <= me
				                        ),
				                        '納入品目_仕入単価履歴'[F_開始日]
				                    ),
				
				            "月内最終単価",
				                VAR m  = [F_開始月]
				                VAR ms = m
				                VAR me = EOMONTH ( m, 0 )
				                VAR k1 = [F_納入品目番号]
				                VAR k2 = [F_仕入先番号]
				                VAR dLast =
				                    MAXX (
				                        FILTER (
				                            ALL ( '納入品目_仕入単価履歴' ),
				                            '納入品目_仕入単価履歴'[F_納入品目番号] = k1
				                                && '納入品目_仕入単価履歴'[F_仕入先番号] = k2
				                                && '納入品目_仕入単価履歴'[F_開始日] >= ms
				                                && '納入品目_仕入単価履歴'[F_開始日] <= me
				                        ),
				                        '納入品目_仕入単価履歴'[F_開始日]
				                    )
				                RETURN
				                    MAXX (
				                        FILTER (
				                            ALL ( '納入品目_仕入単価履歴' ),
				                            '納入品目_仕入単価履歴'[F_納入品目番号] = k1
				                                && '納入品目_仕入単価履歴'[F_仕入先番号] = k2
				                                && '納入品目_仕入単価履歴'[F_開始日] = dLast
				                        ),
				                        '納入品目_仕入単価履歴'[F_契約単価]
				                    ),
				
				            "月初時点単価",
				                VAR m  = [F_開始月]
				                VAR ms = m
				                VAR me = EOMONTH ( m, 0 )
				                VAR k1 = [F_納入品目番号]
				                VAR k2 = [F_仕入先番号]
				
				                VAR dPrev =
				                    MAXX (
				                        FILTER (
				                            ALL ( '納入品目_仕入単価履歴' ),
				                            '納入品目_仕入単価履歴'[F_納入品目番号] = k1
				                                && '納入品目_仕入単価履歴'[F_仕入先番号] = k2
				                                && '納入品目_仕入単価履歴'[F_開始日] < ms
				                                && NOT ISBLANK ( '納入品目_仕入単価履歴'[F_契約単価] )
				                        ),
				                        '納入品目_仕入単価履歴'[F_開始日]
				                    )
				
				                VAR prevPrice =
				                    MAXX (
				                        FILTER (
				                            ALL ( '納入品目_仕入単価履歴' ),
				                            '納入品目_仕入単価履歴'[F_納入品目番号] = k1
				                                && '納入品目_仕入単価履歴'[F_仕入先番号] = k2
				                                && '納入品目_仕入単価履歴'[F_開始日] = dPrev
				                        ),
				                        '納入品目_仕入単価履歴'[F_契約単価]
				                    )
				
				                VAR dFirstInMonth =
				                    MINX (
				                        FILTER (
				                            ALL ( '納入品目_仕入単価履歴' ),
				                            '納入品目_仕入単価履歴'[F_納入品目番号] = k1
				                                && '納入品目_仕入単価履歴'[F_仕入先番号] = k2
				                                && '納入品目_仕入単価履歴'[F_開始日] >= ms
				                                && '納入品目_仕入単価履歴'[F_開始日] <= me
				                        ),
				                        '納入品目_仕入単価履歴'[F_開始日]
				                    )
				
				                VAR firstInMonthPrice =
				                    MAXX (
				                        FILTER (
				                            ALL ( '納入品目_仕入単価履歴' ),
				                            '納入品目_仕入単価履歴'[F_納入品目番号] = k1
				                                && '納入品目_仕入単価履歴'[F_仕入先番号] = k2
				                                && '納入品目_仕入単価履歴'[F_開始日] = dFirstInMonth
				                        ),
				                        '納入品目_仕入単価履歴'[F_契約単価]
				                    )
				
				                RETURN
				                    COALESCE ( prevPrice, firstInMonthPrice ),
				
				            "純増減額",
				                VAR m  = [F_開始月]
				                VAR ms = m
				                VAR me = EOMONTH ( m, 0 )
				                VAR k1 = [F_納入品目番号]
				                VAR k2 = [F_仕入先番号]
				
				                VAR dLast =
				                    MAXX (
				                        FILTER (
				                            ALL ( '納入品目_仕入単価履歴' ),
				                            '納入品目_仕入単価履歴'[F_納入品目番号] = k1
				                                && '納入品目_仕入単価履歴'[F_仕入先番号] = k2
				                                && '納入品目_仕入単価履歴'[F_開始日] >= ms
				                                && '納入品目_仕入単価履歴'[F_開始日] <= me
				                        ),
				                        '納入品目_仕入単価履歴'[F_開始日]
				                    )
				
				                VAR lastPrice =
				                    MAXX (
				                        FILTER (
				                            ALL ( '納入品目_仕入単価履歴' ),
				                            '納入品目_仕入単価履歴'[F_納入品目番号] = k1
				                                && '納入品目_仕入単価履歴'[F_仕入先番号] = k2
				                                && '納入品目_仕入単価履歴'[F_開始日] = dLast
				                        ),
				                        '納入品目_仕入単価履歴'[F_契約単価]
				                    )
				
				                VAR dPrev =
				                    MAXX (
				                        FILTER (
				                            ALL ( '納入品目_仕入単価履歴' ),
				                            '納入品目_仕入単価履歴'[F_納入品目番号] = k1
				                                && '納入品目_仕入単価履歴'[F_仕入先番号] = k2
				                                && '納入品目_仕入単価履歴'[F_開始日] < ms
				                                && NOT ISBLANK ( '納入品目_仕入単価履歴'[F_契約単価] )
				                        ),
				                        '納入品目_仕入単価履歴'[F_開始日]
				                    )
				
				                VAR prevPrice =
				                    MAXX (
				                        FILTER (
				                            ALL ( '納入品目_仕入単価履歴' ),
				                            '納入品目_仕入単価履歴'[F_納入品目番号] = k1
				                                && '納入品目_仕入単価履歴'[F_仕入先番号] = k2
				                                && '納入品目_仕入単価履歴'[F_開始日] = dPrev
				                        ),
				                        '納入品目_仕入単価履歴'[F_契約単価]
				                    )
				
				                VAR dFirstInMonth =
				                    MINX (
				                        FILTER (
				                            ALL ( '納入品目_仕入単価履歴' ),
				                            '納入品目_仕入単価履歴'[F_納入品目番号] = k1
				                                && '納入品目_仕入単価履歴'[F_仕入先番号] = k2
				                                && '納入品目_仕入単価履歴'[F_開始日] >= ms
				                                && '納入品目_仕入単価履歴'[F_開始日] <= me
				                        ),
				                        '納入品目_仕入単価履歴'[F_開始日]
				                    )
				
				                VAR firstInMonthPrice =
				                    MAXX (
				                        FILTER (
				                            ALL ( '納入品目_仕入単価履歴' ),
				                            '納入品目_仕入単価履歴'[F_納入品目番号] = k1
				                                && '納入品目_仕入単価履歴'[F_仕入先番号] = k2
				                                && '納入品目_仕入単価履歴'[F_開始日] = dFirstInMonth
				                        ),
				                        '納入品目_仕入単価履歴'[F_契約単価]
				                    )
				
				                VAR basePrice =
				                    COALESCE ( prevPrice, firstInMonthPrice )
				
				                RETURN
				                    IF (
				                        ISBLANK ( basePrice ) || ISBLANK ( lastPrice ),
				                        BLANK (),
				                        lastPrice - basePrice
				                    )
				        ),
				        [月内イベント件数] > 0
				    )

	annotation PBI_Id = 97a610f554814201a035ab780694db7a


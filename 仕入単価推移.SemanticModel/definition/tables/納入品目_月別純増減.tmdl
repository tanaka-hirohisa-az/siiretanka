table 納入品目_月別純増減
	lineageTag: c2eb528c-b7d3-4af3-bf16-627d7aa4792d

	measure 月別_純増減額合計_品目_明細 =
			
			CALCULATE (
			    SUM ( '納入品目_月別純増減'[純増減額] ),
			    TREATAS (
			        VALUES ( '納入品目_値上げイベント'[F_開始月] ),
			        '納入品目_月別純増減'[F_開始月]
			    ),
			    TREATAS (
			        VALUES ( '納入品目_値上げイベント'[F_納入品目番号] ),
			        '納入品目_月別純増減'[F_納入品目番号]
			    ),
			    TREATAS (
			        VALUES ( '納入品目_値上げイベント'[F_仕入先番号] ),
			        '納入品目_月別純増減'[F_仕入先番号]
			    )
			)
		lineageTag: 692ac25f-f71f-49c6-94c0-a1ac2d89906d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 月別_純値下げ額合計_品目 =
			
			VAR vMonth =
			    SELECTEDVALUE ( '納入品目_値上げイベント'[F_開始月] )
			VAR vItem =
			    SELECTEDVALUE ( '納入品目_値上げイベント'[F_納入品目番号] )
			RETURN
			    CALCULATE (
			        SUMX (
			            FILTER ( '納入品目_月別純増減', '納入品目_月別純増減'[純増減額] < 0 ),
			            '納入品目_月別純増減'[純増減額]
			        ),
			        REMOVEFILTERS ( '納入品目_値上げイベント' ),
			        TREATAS ( { vMonth }, '納入品目_月別純増減'[F_開始月] ),
			        TREATAS ( { vItem }, '納入品目_月別純増減'[F_納入品目番号] )
			    )
		lineageTag: 2f71c3a4-d318-425d-845f-2766316705b9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 月別_純値上げ額合計_品目 =
			
			VAR vMonth =
			    SELECTEDVALUE ( '納入品目_値上げイベント'[F_開始月] )
			VAR vItem =
			    SELECTEDVALUE ( '納入品目_値上げイベント'[F_納入品目番号] )
			RETURN
			    CALCULATE (
			        SUMX (
			            FILTER ( '納入品目_月別純増減', '納入品目_月別純増減'[純増減額] > 0 ),
			            '納入品目_月別純増減'[純増減額]
			        ),
			        REMOVEFILTERS ( '納入品目_値上げイベント' ),
			        TREATAS ( { vMonth }, '納入品目_月別純増減'[F_開始月] ),
			        TREATAS ( { vItem }, '納入品目_月別純増減'[F_納入品目番号] )
			    )
		lineageTag: fcf2797c-a30d-4f5d-b732-00a73ce57c23

		annotation PBI_FormatHint = {"isGeneralNumber":true}


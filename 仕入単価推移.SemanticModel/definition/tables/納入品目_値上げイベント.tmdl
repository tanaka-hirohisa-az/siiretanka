	measure 月別_値上げ額_合計_品目 =
			
			CALCULATE (
			    SUM ( '納入品目_値上げイベント'[値上げ額] ),
			    '納入品目_値上げイベント'[値上げ額] > 0
			)
		lineageTag: 70af26c2-ba2a-44dc-8084-5e608c69004d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 月別_値下げ額_合計_品目 =
			
			CALCULATE (
			    SUM ( '納入品目_値上げイベント'[値上げ額] ),
			    '納入品目_値上げイベント'[値上げ額] < 0
			)
		lineageTag: 31f5b2f5-5b65-40e8-81a8-165e4fd7a6f1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 1件あたり_値上げ額_平均_品目 =
			
			AVERAGEX (
			    FILTER ( '納入品目_値上げイベント', '納入品目_値上げイベント'[値上げ額] > 0 ),
			    '納入品目_値上げイベント'[値上げ額]
			)
		lineageTag: df82e47a-5536-4194-baa5-8d2322396592

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 1件あたり_値下げ額_平均_品目 =
			
			AVERAGEX (
			    FILTER ( '納入品目_値上げイベント', '納入品目_値上げイベント'[値上げ額] < 0 ),
			    '納入品目_値上げイベント'[値上げ額]
			)
		lineageTag: 98e5ba1e-2c84-45f9-a6b2-f0cb7adcefa7


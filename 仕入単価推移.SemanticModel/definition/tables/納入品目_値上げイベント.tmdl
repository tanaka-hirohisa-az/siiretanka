		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 1件あたり単価改定額（ABS）平均 = ```
			
			AVERAGEX (
			    '納入品目_値上げイベント',
			    ABS ( '納入品目_値上げイベント'[値上げ額] )
			)
			

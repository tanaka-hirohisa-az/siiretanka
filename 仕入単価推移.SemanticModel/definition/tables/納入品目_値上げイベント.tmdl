	column 年間予測影響額_値下げのみ_絶対値
		lineageTag: dd23ce32-393b-41e5-a382-9b2f925580ff
		summarizeBy: sum
		isNameInferred
		sourceColumn: [年間予測影響額_値下げのみ_絶対値]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition 納入品目_値上げイベント = calculated
		mode: import
		source =
				
				ADDCOLUMNS (
				    FILTER (
				        '納入品目_仕入単価履歴',
				        NOT ISBLANK ( '納入品目_仕入単価履歴'[値上げ額] )
				            && '納入品目_仕入単価履歴'[値上げ額] <> 0
				    ),
				
				    "値上げ率",
				        DIVIDE ( [値上げ額], [前回単価] ),
				
				    "改定方向",
				        IF ( [値上げ額] > 0, "値上げ", "値下げ" ),
				
				    "絶対値上げ額",
				        ABS ( [値上げ額] ),
				
				    "外れ値フラグ",
				        IF ( ABS ( [値上げ額] ) >= 50000, 1, 0 ),
				
				    "年間予測影響額",
				        [値上げ額]
				            * LOOKUPVALUE (
				                '納入品目_年平均稼働量'[直近12か月稼働量],
				                '納入品目_年平均稼働量'[F_納入品目番号], [F_納入品目番号]
				            ),
				
				    "値上げ額_値上げのみ",
				        IF ( [値上げ額] > 0, [値上げ額], BLANK () ),
				
				    "値下げ額_値下げのみ",
				        IF ( [値上げ額] < 0, [値上げ額], BLANK () ),
				
				    "値下げ額_値下げのみ_絶対値",
				        IF ( [値上げ額] < 0, ABS ( [値上げ額] ), BLANK () ),
				
				    "年間予測影響額_値上げのみ",
				        VAR qty_up =
				            LOOKUPVALUE (
				                '納入品目_年平均稼働量'[直近12か月稼働量],
				                '納入品目_年平均稼働量'[F_納入品目番号], [F_納入品目番号]
				            )
				        RETURN
				            IF ( [値上げ額] > 0, [値上げ額] * qty_up, BLANK () ),
				
				    "年間予測影響額_値下げのみ",
				        VAR qty_down =
				            LOOKUPVALUE (
				                '納入品目_年平均稼働量'[直近12か月稼働量],
				                '納入品目_年平均稼働量'[F_納入品目番号], [F_納入品目番号]
				            )
				        RETURN
				            IF ( [値上げ額] < 0, [値上げ額] * qty_down, BLANK () ),
				
				    "年間予測影響額_値下げのみ_絶対値",
				        VAR qty_down_abs =
				            LOOKUPVALUE (
				                '納入品目_年平均稼働量'[直近12か月稼働量],
				                '納入品目_年平均稼働量'[F_納入品目番号], [F_納入品目番号]
				            )
				        RETURN
				            IF ( [値上げ額] < 0, ABS ( [値上げ額] * qty_down_abs ), BLANK () )
				)

	annotation PBI_Id = 6466698a0a864d0cbc2aada4f4d477d9


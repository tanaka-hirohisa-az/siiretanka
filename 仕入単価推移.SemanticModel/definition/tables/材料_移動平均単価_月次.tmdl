	column 直近12か月稼働量
		lineageTag: d6e7f8a9-b0c1-4923-4e5f-6a7b2e3f4a5b
		summarizeBy: none
		isNameInferred
		sourceColumn: [直近12か月稼働量]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition 材料_移動平均単価_月次 = calculated
		mode: import
		source = ```

				VAR __Ev0 =
				    FILTER (
				        'TB_仕入実績情報',
				        NOT ISBLANK ( 'TB_仕入実績情報'[F_品目番号] )
				            && NOT ISBLANK ( 'TB_仕入実績情報'[F_仕入日] )
				            && 'TB_仕入実績情報'[F_仕入数] > 0
				    )

				VAR __Ev =
				    SELECTCOLUMNS (
				        __Ev0,
				        "__材料番号",
				            TRIM (
				                SUBSTITUTE (
				                    'TB_仕入実績情報'[F_品目番号],
				                    UNICHAR ( 12288 ),
				                    " "
				                )
				            ) & "",
				        "__月",
				            EOMONTH ( DATEVALUE ( 'TB_仕入実績情報'[F_仕入日] ), -1 ) + 1,
				        "__数", 'TB_仕入実績情報'[F_仕入数],
				        "__額", 'TB_仕入実績情報'[F_仕入数] * 'TB_仕入実績情報'[F_単価]
				    )

				VAR __M =
				    GROUPBY (
				        __Ev,
				        [__材料番号],
				        [__月],
				        "__月数計", SUMX ( CURRENTGROUP (), [__数] ),
				        "__月額計", SUMX ( CURRENTGROUP (), [__額] )
				    )

				VAR __Shift =
				    SELECTCOLUMNS (
				        CROSSJOIN (
				            __M,
				            SELECTCOLUMNS ( GENERATESERIES ( 0, 11, 1 ), "__k", [Value] )
				        ),
				        "__材料番号", [__材料番号],
				        "__基準月",   EDATE ( [__月], [__k] ),
				        "__数c",      [__月数計],
				        "__額c",      [__月額計]
				    )

				VAR __Agg0 =
				    GROUPBY (
				        __Shift,
				        [__材料番号],
				        [__基準月],
				        "__数計", SUMX ( CURRENTGROUP (), [__数c] ),
				        "__額計", SUMX ( CURRENTGROUP (), [__額c] )
				    )

				VAR __Mats =
				    GROUPBY (
				        __M,
				        [__材料番号],
				        "__終月", MAXX ( CURRENTGROUP (), [__月] )
				    )

				VAR __Agg =
				    ADDCOLUMNS (
				        FILTER (
				            NATURALINNERJOIN ( __Agg0, __Mats ),
				            [__基準月] <= [__終月]
				                && [__数計] > 0
				        ),
				        "__移動平均単価", DIVIDE ( [__額計], [__数計] )
				    )

				VAR __PrevT =
				    SELECTCOLUMNS (
				        __Agg,
				        "__材料番号", [__材料番号],
				        "__基準月",   EDATE ( [__基準月], 1 ),
				        "__前月単価", [__移動平均単価]
				    )

				VAR __Cur =
				    SELECTCOLUMNS (
				        __M,
				        "__材料番号", [__材料番号],
				        "__基準月",   [__月],
				        "__月内数",   [__月数計],
				        "__月内額",   [__月額計]
				    )

				VAR __J =
				    NATURALLEFTOUTERJOIN (
				        NATURALLEFTOUTERJOIN ( __Agg, __PrevT ),
				        __Cur
				    )

				VAR __Final =
				    ADDCOLUMNS (
				        __J,
				        "__値上げ額",
				            IF (
				                NOT ISBLANK ( [__前月単価] ),
				                [__移動平均単価] - [__前月単価]
				            ),
				        "__稼働量",
				            LOOKUPVALUE (
				                '材料_年平均稼働量_仕入'[直近12か月稼働量],
				                '材料_年平均稼働量_仕入'[F_材料番号], [__材料番号]
				            )
				    )

				RETURN
				    SELECTCOLUMNS (
				        __Final,
				        "F_材料番号",     [__材料番号],
				        "F_開始月",       [__基準月],
				        "移動平均単価",   [__移動平均単価],
				        "前月移動平均単価", [__前月単価],
				        "月内仕入数",     [__月内数],
				        "月内仕入金額",   [__月内額],
				        "値上げ額",       [__値上げ額],
				        "値上げ率",       DIVIDE ( [__値上げ額], [__前月単価] ),
				        "年間予測影響額", [__値上げ額] * [__稼働量],
				        "年間予測影響額_値上げのみ",
				            IF ( [__値上げ額] > 0, [__値上げ額] * [__稼働量] ),
				        "年間予測影響額_値下げのみ",
				            IF ( [__値上げ額] < 0, [__値上げ額] * [__稼働量] ),
				        "直近12か月稼働量", [__稼働量]
				    )

				```

	annotation PBI_Id = d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9

	column 直近12か月稼働量
		lineageTag: d6e7f8a9-b0c1-4923-4e5f-6a7b2e3f4a5b
		summarizeBy: none
		isNameInferred
		sourceColumn: [直近12か月稼働量]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition 材料_移動平均単価_月次 = calculated
		mode: import
		source = ```

				VAR __Ev0 =
				    FILTER (
				        'TB_仕入実績情報',
				        NOT ISBLANK ( 'TB_仕入実績情報'[F_品目番号] )
				            && NOT ISBLANK ( 'TB_仕入実績情報'[F_仕入日] )
				            && 'TB_仕入実績情報'[F_仕入数] > 0
				    )

				VAR __Ev =
				    SELECTCOLUMNS (
				        __Ev0,
				        "__材料番号",
				            TRIM (
				                SUBSTITUTE (
				                    'TB_仕入実績情報'[F_品目番号],
				                    UNICHAR ( 12288 ),
				                    " "
				                )
				            ) & "",
				        "__日付", DATEVALUE ( 'TB_仕入実績情報'[F_仕入日] ),
				        "__数",   'TB_仕入実績情報'[F_仕入数],
				        "__額",   'TB_仕入実績情報'[F_仕入数] * 'TB_仕入実績情報'[F_単価]
				    )

				VAR __MinM =
				    EOMONTH ( MINX ( __Ev, [__日付] ), -1 ) + 1

				VAR __MaxM =
				    EOMONTH ( MAXX ( __Ev, [__日付] ), -1 ) + 1

				VAR __Cnt =
				    DATEDIFF ( __MinM, __MaxM, MONTH )

				VAR __Months =
				    SELECTCOLUMNS (
				        GENERATESERIES ( 0, __Cnt, 1 ),
				        "__月", EDATE ( __MinM, [Value] )
				    )

				VAR __Mats =
				    GROUPBY (
				        __Ev,
				        [__材料番号],
				        "__初日", MINX ( CURRENTGROUP (), [__日付] ),
				        "__終日", MAXX ( CURRENTGROUP (), [__日付] )
				    )

				VAR __Grid =
				    FILTER (
				        CROSSJOIN ( __Mats, __Months ),
				        [__月] >= EOMONTH ( [__初日], -1 ) + 1
				            && [__月] <= EOMONTH ( [__終日], -1 ) + 1
				    )

				VAR __Calc =
				    ADDCOLUMNS (
				        __Grid,
				        "__数計",
				            VAR k = [__材料番号]
				            VAR s = EDATE ( [__月], -11 )
				            VAR e = EDATE ( [__月], 1 )
				            RETURN
				                SUMX (
				                    FILTER (
				                        __Ev,
				                        [__材料番号] = k
				                            && [__日付] >= s
				                            && [__日付] < e
				                    ),
				                    [__数]
				                ),
				        "__額計",
				            VAR k = [__材料番号]
				            VAR s = EDATE ( [__月], -11 )
				            VAR e = EDATE ( [__月], 1 )
				            RETURN
				                SUMX (
				                    FILTER (
				                        __Ev,
				                        [__材料番号] = k
				                            && [__日付] >= s
				                            && [__日付] < e
				                    ),
				                    [__額]
				                ),
				        "__月内数",
				            VAR k = [__材料番号]
				            VAR s = [__月]
				            VAR e = EDATE ( [__月], 1 )
				            RETURN
				                SUMX (
				                    FILTER (
				                        __Ev,
				                        [__材料番号] = k
				                            && [__日付] >= s
				                            && [__日付] < e
				                    ),
				                    [__数]
				                ),
				        "__月内額",
				            VAR k = [__材料番号]
				            VAR s = [__月]
				            VAR e = EDATE ( [__月], 1 )
				            RETURN
				                SUMX (
				                    FILTER (
				                        __Ev,
				                        [__材料番号] = k
				                            && [__日付] >= s
				                            && [__日付] < e
				                    ),
				                    [__額]
				                )
				    )

				VAR __Avg =
				    ADDCOLUMNS (
				        FILTER ( __Calc, [__数計] > 0 ),
				        "__移動平均単価", DIVIDE ( [__額計], [__数計] )
				    )

				VAR __Prev =
				    ADDCOLUMNS (
				        __Avg,
				        "__前月単価",
				            VAR k = [__材料番号]
				            VAR pm = EDATE ( [__月], -1 )
				            RETURN
				                MAXX (
				                    FILTER (
				                        __Avg,
				                        [__材料番号] = k
				                            && [__月] = pm
				                    ),
				                    [__移動平均単価]
				                ),
				        "__稼働量",
				            LOOKUPVALUE (
				                '材料_年平均稼働量_仕入'[直近12か月稼働量],
				                '材料_年平均稼働量_仕入'[F_材料番号], [__材料番号]
				            )
				    )

				VAR __Final =
				    ADDCOLUMNS (
				        __Prev,
				        "__値上げ額",
				            IF (
				                NOT ISBLANK ( [__前月単価] ),
				                [__移動平均単価] - [__前月単価]
				            )
				    )

				RETURN
				    SELECTCOLUMNS (
				        __Final,
				        "F_材料番号",     [__材料番号],
				        "F_開始月",       [__月],
				        "移動平均単価",   [__移動平均単価],
				        "前月移動平均単価", [__前月単価],
				        "月内仕入数",     [__月内数],
				        "月内仕入金額",   [__月内額],
				        "値上げ額",       [__値上げ額],
				        "値上げ率",       DIVIDE ( [__値上げ額], [__前月単価] ),
				        "年間予測影響額", [__値上げ額] * [__稼働量],
				        "年間予測影響額_値上げのみ",
				            IF ( [__値上げ額] > 0, [__値上げ額] * [__稼働量] ),
				        "年間予測影響額_値下げのみ",
				            IF ( [__値上げ額] < 0, [__値上げ額] * [__稼働量] ),
				        "直近12か月稼働量", [__稼働量]
				    )

				```

	annotation PBI_Id = d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9

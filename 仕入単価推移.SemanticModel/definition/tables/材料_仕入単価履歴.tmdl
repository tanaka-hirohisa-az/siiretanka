	column F_開始月
		formatString: General Date
		lineageTag: 09520f91-6f88-47a0-be61-ee529f06569e
		summarizeBy: none
		isNameInferred
		sourceColumn: [F_開始月]

		variation バリエーション
			isDefault
			relationship: ad20f89d-550f-47c9-8bb9-c32883e69d47
			defaultHierarchy: LocalDateTable_c971b18c-8aa0-41d1-ade7-bc5899357ef9.日付の階層

		annotation SummarizationSetBy = Automatic

	partition 材料_仕入単価履歴 = calculated
		mode: import
		source = ```
				
				VAR __Base =
				    SELECTCOLUMNS (
				        'TB_材料仕入先単価情報',
				        "F_材料番号",
				            TRIM (
				                SUBSTITUTE (
				                    'TB_材料仕入先単価情報'[F_材料番号],
				                    UNICHAR ( 12288 ),
				                    " "
				                )
				            ),
				        "F_開始日",
				            VAR d = 'TB_材料仕入先単価情報'[F_開始日]
				            RETURN
				                DATE (
				                    IF ( YEAR ( d ) < 1900, YEAR ( d ) + 1800, YEAR ( d ) ),
				                    MONTH ( d ),
				                    DAY ( d )
				                ),
				        "F_仕入先番号", 'TB_材料仕入先単価情報'[F_仕入先番号],
				        "F_契約単価",   'TB_材料仕入先単価情報'[F_契約単価]
				    )
				
				VAR __Filtered =
				    FILTER (
				        __Base,
				        NOT ISBLANK ( [F_材料番号] )
				            && NOT ISBLANK ( [F_開始日] )
				            && NOT ISBLANK ( [F_仕入先番号] )
				    )
				
				RETURN
				    ADDCOLUMNS (
				        __Filtered,
				
				        // 月キー（列）：月初日（※月別軸はこれを使う）
				        "F_開始月",
				            DATE ( YEAR ( [F_開始日] ), MONTH ( [F_開始日] ), 1 ),
				
				        // 1) 終了日（次開始日の前日）
				        "F_終了日",
				            VAR k1 = [F_材料番号]
				            VAR k2 = [F_仕入先番号]
				            VAR d0 = [F_開始日]
				            VAR nextD =
				                MINX (
				                    FILTER (
				                        __Filtered,
				                        [F_材料番号] = k1
				                            && [F_仕入先番号] = k2
				                            && [F_開始日] > d0
				                    ),
				                    [F_開始日]
				                )
				            RETURN
				                IF ( ISBLANK ( nextD ), BLANK (), nextD - 1 ),
				
				        // 2) 仕入先略称
				        "F_仕入先略称",
				            LOOKUPVALUE (
				                'TB_仕入先情報'[F_仕入先略称],
				                'TB_仕入先情報'[F_仕入先番号], [F_仕入先番号]
				            ),
				
				        // 3) 前回単価
				        "前回単価",
				            VAR k1 = [F_材料番号]
				            VAR k2 = [F_仕入先番号]
				            VAR d0 = [F_開始日]
				            VAR prevD =
				                MAXX (
				                    FILTER (
				                        __Filtered,
				                        [F_材料番号] = k1
				                            && [F_仕入先番号] = k2
				                            && [F_開始日] < d0
				                            && NOT ISBLANK ( [F_契約単価] )
				                    ),
				                    [F_開始日]
				                )
				            RETURN
				                MAXX (
				                    FILTER (
				                        __Filtered,
				                        [F_材料番号] = k1
				                            && [F_仕入先番号] = k2
				                            && [F_開始日] = prevD
				                    ),
				                    [F_契約単価]
				                ),
				
				        // 4) 値上げ額（兄弟列参照禁止なのでここで完結）
				        "値上げ額",
				            VAR cur = [F_契約単価]
				            VAR k1 = [F_材料番号]
				            VAR k2 = [F_仕入先番号]
				            VAR d0 = [F_開始日]
				            VAR prevD =
				                MAXX (
				                    FILTER (
				                        __Filtered,
				                        [F_材料番号] = k1
				                            && [F_仕入先番号] = k2
				                            && [F_開始日] < d0
				                            && NOT ISBLANK ( [F_契約単価] )
				                    ),
				                    [F_開始日]
				                )
				            VAR prev =
				                MAXX (
				                    FILTER (
				                        __Filtered,
				                        [F_材料番号] = k1
				                            && [F_仕入先番号] = k2
				                            && [F_開始日] = prevD
				                    ),
				                    [F_契約単価]
				                )
				            RETURN
				                IF ( ISBLANK ( prev ) || ISBLANK ( cur ), BLANK (), cur - prev )
				    )
				
				```

	annotation PBI_Id = 11e3304641c940e89b5e3ac5623c67bd


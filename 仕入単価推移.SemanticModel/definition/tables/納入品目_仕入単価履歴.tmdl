	column F_開始月_YYYYMM
		formatString: 0
		lineageTag: 779d9da3-5ed5-46cb-bcaa-0cbec9a8f87a
		summarizeBy: sum
		isNameInferred
		sourceColumn: [F_開始月_YYYYMM]

		annotation SummarizationSetBy = Automatic

	partition 納入品目_仕入単価履歴 = calculated
		mode: import
		source =
				
				VAR __Base =
				    SELECTCOLUMNS (
				        'TB_納入品目仕入先単価情報',
				        "F_納入品目番号",
				            TRIM (
				                SUBSTITUTE (
				                    'TB_納入品目仕入先単価情報'[F_納入品目番号],
				                    UNICHAR ( 12288 ),
				                    " "
				                )
				            ),
				        "F_開始日",
				            VAR d = 'TB_納入品目仕入先単価情報'[F_開始日]
				            RETURN
				                DATE (
				                    IF ( YEAR ( d ) < 1900, YEAR ( d ) + 1800, YEAR ( d ) ),
				                    MONTH ( d ),
				                    DAY ( d )
				                ),
				        "F_仕入先番号", 'TB_納入品目仕入先単価情報'[F_仕入先番号],
				        "F_契約単価",   'TB_納入品目仕入先単価情報'[F_契約単価]
				    )
				
				VAR __Filtered =
				    FILTER (
				        __Base,
				        NOT ISBLANK ( [F_納入品目番号] )
				            && NOT ISBLANK ( [F_開始日] )
				    )
				
				RETURN
				    ADDCOLUMNS (
				        __Filtered,
				
				        "F_開始月",
				            DATE ( YEAR ( [F_開始日] ), MONTH ( [F_開始日] ), 1 ),
				
				        "F_開始月_YYYYMM",
				            YEAR ( [F_開始日] ) * 100 + MONTH ( [F_開始日] ),
				
				        "F_終了日",
				            VAR k1 = [F_納入品目番号]
				            VAR k2 = [F_仕入先番号]
				            VAR d0 = [F_開始日]
				            VAR nextD =
				                MINX (
				                    FILTER (
				                        __Filtered,
				                        [F_納入品目番号] = k1
				                            && [F_仕入先番号] = k2
				                            && [F_開始日] > d0
				                    ),
				                    [F_開始日]
				                )
				            RETURN
				                IF ( ISBLANK ( nextD ), BLANK (), nextD - 1 ),
				
				        "F_仕入先略称",
				            LOOKUPVALUE (
				                'TB_仕入先情報'[F_仕入先略称],
				                'TB_仕入先情報'[F_仕入先番号], [F_仕入先番号]
				            ),
				
				        "前回単価",
				            VAR k1 = [F_納入品目番号]
				            VAR k2 = [F_仕入先番号]
				            VAR d0 = [F_開始日]
				            VAR prevD =
				                MAXX (
				                    FILTER (
				                        __Filtered,
				                        [F_納入品目番号] = k1
				                            && [F_仕入先番号] = k2
				                            && [F_開始日] < d0
				                            && NOT ISBLANK ( [F_契約単価] )
				                    ),
				                    [F_開始日]
				                )
				            RETURN
				                MAXX (
				                    FILTER (
				                        __Filtered,
				                        [F_納入品目番号] = k1
				                            && [F_仕入先番号] = k2
				                            && [F_開始日] = prevD
				                    ),
				                    [F_契約単価]
				                ),
				
				        "値上げ額",
				            VAR cur = [F_契約単価]
				            VAR k1 = [F_納入品目番号]
				            VAR k2 = [F_仕入先番号]
				            VAR d0 = [F_開始日]
				            VAR prevD =
				                MAXX (
				                    FILTER (
				                        __Filtered,
				                        [F_納入品目番号] = k1
				                            && [F_仕入先番号] = k2
				                            && [F_開始日] < d0
				                            && NOT ISBLANK ( [F_契約単価] )
				                    ),
				                    [F_開始日]
				                )
				            VAR prev =
				                MAXX (
				                    FILTER (
				                        __Filtered,
				                        [F_納入品目番号] = k1
				                            && [F_仕入先番号] = k2
				                            && [F_開始日] = prevD
				                    ),
				                    [F_契約単価]
				                )
				            RETURN
				                IF ( ISBLANK ( prev ) || ISBLANK ( cur ), BLANK (), cur - prev )
				    )

	annotation PBI_Id = 72fdf645eca74ab39e9771e74a5767b3


		summarizeBy: none
		isNameInferred
		sourceColumn: [月内最初開始日]

		variation バリエーション
			isDefault
			relationship: e3410f13-581a-43a7-a508-dae85325853d
			defaultHierarchy: LocalDateTable_ff757024-8af9-40bf-8170-5b4e6e43ced8.日付の階層

		annotation SummarizationSetBy = Automatic

	partition 材料_月別純増減 = calculated
		mode: import
		source =
				
				VAR __Ev =
				    '材料_値上げイベント'
				
				VAR __Base =
				    SUMMARIZE (
				        __Ev,
				        [F_開始月],
				        [F_材料番号],
				        [F_仕入先番号],
				        [月次キー]
				    )
				
				RETURN
				    ADDCOLUMNS (
				        __Base,
				
				        "F_仕入先略称",
				            LOOKUPVALUE (
				                'TB_仕入先情報'[F_仕入先略称],
				                'TB_仕入先情報'[F_仕入先番号], [F_仕入先番号]
				            ),
				
				        "月内イベント件数",
				            VAR k = [月次キー]
				            RETURN
				                COUNTROWS (
				                    FILTER ( __Ev, [月次キー] = k )
				                ),
				
				        "月内最初開始日",
				            VAR k = [月次キー]
				            RETURN
				                MINX (
				                    FILTER ( __Ev, [月次キー] = k ),
				                    [F_開始日]
				                ),
				
				        "月内最終開始日",
				            VAR k = [月次キー]
				            RETURN
				                MAXX (
				                    FILTER ( __Ev, [月次キー] = k ),
				                    [F_開始日]
				                ),
				
				        "月初時点単価",
				            VAR k = [月次キー]
				            VAR dFirst =
				                MINX (
				                    FILTER ( __Ev, [月次キー] = k ),
				                    [F_開始日]
				                )
				            RETURN
				                MAXX (
				                    FILTER (
				                        __Ev,
				                        [月次キー] = k
				                            && [F_開始日] = dFirst
				                    ),
				                    [前回単価]
				                ),
				
				        "月内最終単価",
				            VAR k = [月次キー]
				            VAR dLast =
				                MAXX (
				                    FILTER ( __Ev, [月次キー] = k ),
				                    [F_開始日]
				                )
				            RETURN
				                MAXX (
				                    FILTER (
				                        __Ev,
				                        [月次キー] = k
				                            && [F_開始日] = dLast
				                    ),
				                    [F_契約単価]
				                ),
				
				        "純増減額",
				            VAR k = [月次キー]
				            RETURN
				                SUMX (
				                    FILTER ( __Ev, [月次キー] = k ),
				                    [値上げ額]
				                ),
				
				        "月別_純値上げ額合計_材料",
				            VAR k = [月次キー]
				            RETURN
				                SUMX (
				                    FILTER ( __Ev, [月次キー] = k && [値上げ額] > 0 ),
				                    [値上げ額]
				                ),
				
				        "月別_純値下げ額合計_材料",
				            VAR k = [月次キー]
				            RETURN
				                SUMX (
				                    FILTER ( __Ev, [月次キー] = k && [値上げ額] < 0 ),
				                    [値上げ額]
				                )
				    )

	annotation PBI_Id = cd01f56f58e7482997559a5de8ab3a5f


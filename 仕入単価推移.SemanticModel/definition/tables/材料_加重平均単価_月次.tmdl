	column F_在庫材料番号
		lineageTag: e7f8a9b0-c1d2-4034-5f6a-7b8c3f4a5b6c
		summarizeBy: none
		isNameInferred
		sourceColumn: [F_在庫材料番号]

		annotation SummarizationSetBy = Automatic

	partition 材料_加重平均単価_月次 = calculated
		mode: import
		source = ```
				VAR __Ev0 =
				    FILTER (
				        'TB_仕入実績情報',
				        NOT ISBLANK ( 'TB_仕入実績情報'[F_品目番号] )
				            && NOT ISBLANK ( 'TB_仕入実績情報'[F_仕入日] )
				            && 'TB_仕入実績情報'[F_仕入数] > 0
				    )

				VAR __Ev =
				    SELECTCOLUMNS (
				        __Ev0,
				        "__材料番号",
				            TRIM (
				                SUBSTITUTE (
				                    'TB_仕入実績情報'[F_品目番号],
				                    UNICHAR ( 12288 ),
				                    " "
				                )
				            ) & "",
				        "__月",
				            EOMONTH ( DATEVALUE ( 'TB_仕入実績情報'[F_仕入日] ), -1 ) + 1,
				        "__数", 'TB_仕入実績情報'[F_仕入数],
				        "__額", 'TB_仕入実績情報'[F_仕入数] * 'TB_仕入実績情報'[F_単価]
				    )

				VAR __MatSet =
				    FILTER (
				        DISTINCT (
				            SELECTCOLUMNS (
				                '材料情報',
				                "__材料番号",
				                    TRIM (
				                        SUBSTITUTE (
				                            '材料情報'[F_材料番号],
				                            UNICHAR ( 12288 ),
				                            " "
				                        )
				                    ) & ""
				            )
				        ),
				        [__材料番号] <> ""
				    )

				VAR __EvM =
				    NATURALINNERJOIN ( __Ev, __MatSet )

				VAR __M =
				    GROUPBY (
				        __EvM,
				        [__材料番号],
				        [__月],
				        "__月数計", SUMX ( CURRENTGROUP (), [__数] ),
				        "__月額計", SUMX ( CURRENTGROUP (), [__額] )
				    )

				// 加重平均単価の窓：直近6ヶ月（基準月を含む）
				VAR __Shift =
				    SELECTCOLUMNS (
				        CROSSJOIN (
				            __M,
				            SELECTCOLUMNS ( GENERATESERIES ( 0, 5, 1 ), "__k", [Value] )
				        ),
				        "__材料番号", [__材料番号],
				        "__基準月",   EDATE ( [__月], [__k] ),
				        "__数c",      [__月数計],
				        "__額c",      [__月額計]
				    )

				VAR __Agg0 =
				    GROUPBY (
				        __Shift,
				        [__材料番号],
				        [__基準月],
				        "__数計", SUMX ( CURRENTGROUP (), [__数c] ),
				        "__額計", SUMX ( CURRENTGROUP (), [__額c] )
				    )

				// 稼働量の窓：年間予測影響額用に直近12ヶ月を維持
				VAR __Shift12 =
				    SELECTCOLUMNS (
				        CROSSJOIN (
				            __M,
				            SELECTCOLUMNS ( GENERATESERIES ( 0, 11, 1 ), "__k12", [Value] )
				        ),
				        "__材料番号", [__材料番号],
				        "__基準月",   EDATE ( [__月], [__k12] ),
				        "__数12c",    [__月数計]
				    )

				VAR __Agg12 =
				    GROUPBY (
				        __Shift12,
				        [__材料番号],
				        [__基準月],
				        "__稼働量", SUMX ( CURRENTGROUP (), [__数12c] )
				    )

				VAR __Mats =
				    GROUPBY (
				        __M,
				        [__材料番号],
				        "__終月", MAXX ( CURRENTGROUP (), [__月] )
				    )

				VAR __Agg =
				    ADDCOLUMNS (
				        FILTER (
				            NATURALINNERJOIN ( __Agg0, __Mats ),
				            [__基準月] <= [__終月]
				                && [__数計] > 0
				        ),
				        "__加重平均単価", DIVIDE ( [__額計], [__数計] )
				    )

				VAR __PrevT =
				    SELECTCOLUMNS (
				        __Agg,
				        "__材料番号", [__材料番号],
				        "__基準月",   EDATE ( [__基準月], 1 ),
				        "__前月単価", [__加重平均単価]
				    )

				VAR __Cur =
				    SELECTCOLUMNS (
				        __M,
				        "__材料番号", [__材料番号],
				        "__基準月",   [__月],
				        "__月内数",   [__月数計],
				        "__月内額",   [__月額計]
				    )

				VAR __J =
				    NATURALLEFTOUTERJOIN (
				        NATURALLEFTOUTERJOIN (
				            NATURALLEFTOUTERJOIN ( __Agg, __PrevT ),
				            __Cur
				        ),
				        __Agg12
				    )

				// 前回加重平均単価：
				//   通常は前月時点の6ヶ月加重平均。
				//   前月に窓内仕入がない場合（6ヶ月超の空白明け）は、
				//   それ以前で最も近い仕入月の月内加重平均にフォールバックする。
				VAR __Final =
				    ADDCOLUMNS (
				        __J,
				        "__前回単価",
				            IF (
				                NOT ISBLANK ( [__前月単価] ),
				                [__前月単価],
				                VAR __mat = [__材料番号]
				                VAR __bm  = [__基準月]
				                VAR __pm =
				                    MAXX (
				                        FILTER ( __M, [__材料番号] = __mat && [__月] < __bm ),
				                        [__月]
				                    )
				                RETURN
				                    IF (
				                        NOT ISBLANK ( __pm ),
				                        MAXX (
				                            FILTER ( __M, [__材料番号] = __mat && [__月] = __pm ),
				                            DIVIDE ( [__月額計], [__月数計] )
				                        )
				                    )
				            )
				    )

				VAR __Final2 =
				    ADDCOLUMNS (
				        __Final,
				        "__値上げ額",
				            IF (
				                NOT ISBLANK ( [__前回単価] ),
				                [__加重平均単価] - [__前回単価]
				            )
				    )

				VAR __Map0 =
				    SELECTCOLUMNS (
				        '材料情報',
				        "__材料番号",
				            TRIM (
				                SUBSTITUTE (
				                    '材料情報'[F_材料番号],
				                    UNICHAR ( 12288 ),
				                    " "
				                )
				            ) & "",
				        "__在k", '材料情報'[F_在庫材料番号] & ""
				    )

				VAR __Map =
				    GROUPBY (
				        __Map0,
				        [__材料番号],
				        "__在庫番号", MAXX ( CURRENTGROUP (), [__在k] )
				    )

				VAR __J2 =
				    NATURALLEFTOUTERJOIN ( __Final2, __Map )

				RETURN
				    SELECTCOLUMNS (
				        __J2,
				        "F_在庫材料番号", [__在庫番号],
				        "F_材料番号",     [__材料番号],
				        "F_開始月",       [__基準月],
				        "加重平均単価",   [__加重平均単価],
				        "前回加重平均単価", [__前回単価],
				        "月内仕入数",     [__月内数],
				        "月内仕入金額",   [__月内額],
				        "値上げ額",       [__値上げ額],
				        "値上げ率",       DIVIDE ( [__値上げ額], [__前回単価] ),
				        "年間予測影響額", [__値上げ額] * [__稼働量],
				        "年間予測影響額_値上げのみ",
				            IF ( [__値上げ額] > 0, [__値上げ額] * [__稼働量] ),
				        "年間予測影響額_値下げのみ",
				            IF ( [__値上げ額] < 0, [__値上げ額] * [__稼働量] ),
				        "直近12か月稼働量", [__稼働量]
				    )
				```

	annotation PBI_Id = d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9

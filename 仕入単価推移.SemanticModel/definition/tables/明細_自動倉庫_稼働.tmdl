	partition 明細_自動倉庫_稼働 = calculated
		mode: import
		source = ```
				
				VAR __Base =
				    SELECTCOLUMNS (
				        'TW_自動倉庫',
				        "F_納入品目番号",        'TW_自動倉庫'[F_納入品目番号],
				        "F_状態区分",            'TW_自動倉庫'[F_状態区分],
				        "F_登録時間",            'TW_自動倉庫'[F_登録時間],
				        "F_ファイル抽出時間",    'TW_自動倉庫'[F_ファイル抽出時間],
				        "F_更新時間",            'TW_自動倉庫'[F_更新時間],
				        "F_自動倉庫在庫数",      'TW_自動倉庫'[F_自動倉庫在庫数],
				        "F_平置在庫数",          'TW_自動倉庫'[F_平置在庫数],
				        "F_合計在庫数",          'TW_自動倉庫'[合計在庫数]
				    )
				
				/* Step1：稼働判定＋最新仕入単価（開始日最大） */
				VAR __Step1 =
				    ADDCOLUMNS (
				        __Base,
				
				        /* 稼働判定系 */
				        "最終日付",
				            LOOKUPVALUE (
				                '品目一覧_稼働判定'[最終日付],
				                '品目一覧_稼働判定'[F_納入品目番号], [F_納入品目番号]
				            ),
				
				        "稼働区分",
				            LOOKUPVALUE (
				                '品目一覧_稼働判定'[稼働区分],
				                '品目一覧_稼働判定'[F_納入品目番号], [F_納入品目番号]
				            ),
				
				        "稼働区分Sort",
				            LOOKUPVALUE (
				                '品目一覧_稼働判定'[稼働区分Sort],
				                '品目一覧_稼働判定'[F_納入品目番号], [F_納入品目番号]
				            ),
				
				        "最終日付_取得先区分",
				            LOOKUPVALUE (
				                '品目一覧_稼働判定'[最終日付_取得先区分],
				                '品目一覧_稼働判定'[F_納入品目番号], [F_納入品目番号]
				            ),
				
				        "最終得意先略称",
				            LOOKUPVALUE (
				                '品目一覧_稼働判定'[最終得意先略称],
				                '品目一覧_稼働判定'[F_納入品目番号], [F_納入品目番号]
				            ),
				
				        /* ===== 最新仕入単価（F_開始日が最新） ===== */
				
				        "R_仕入先番号",
				            VAR k =
				                TRIM ( SUBSTITUTE ( [F_納入品目番号], UNICHAR ( 12288 ), " " ) )
				            VAR tLatest =
				                TOPN (
				                    1,
				                    FILTER (
				                        ALL ( 'TB_納入品目仕入先単価情報' ),
				                        TRIM ( SUBSTITUTE ( 'TB_納入品目仕入先単価情報'[F_納入品目番号], UNICHAR ( 12288 ), " " ) ) = k
				                            && NOT ISBLANK ( 'TB_納入品目仕入先単価情報'[F_開始日] )
				                    ),
				                    'TB_納入品目仕入先単価情報'[F_開始日], DESC
				                )
				            RETURN
				                MAXX ( tLatest, 'TB_納入品目仕入先単価情報'[F_仕入先番号] ),
				
				        "F_契約単価",
				            VAR k =
				                TRIM ( SUBSTITUTE ( [F_納入品目番号], UNICHAR ( 12288 ), " " ) )
				            VAR tLatest =
				                TOPN (
				                    1,
				                    FILTER (
				                        ALL ( 'TB_納入品目仕入先単価情報' ),
				                        TRIM ( SUBSTITUTE ( 'TB_納入品目仕入先単価情報'[F_納入品目番号], UNICHAR ( 12288 ), " " ) ) = k
				                            && NOT ISBLANK ( 'TB_納入品目仕入先単価情報'[F_開始日] )
				                    ),
				                    'TB_納入品目仕入先単価情報'[F_開始日], DESC
				                )
				            RETURN
				                MAXX ( tLatest, 'TB_納入品目仕入先単価情報'[F_契約単価] ),
				
				        /* 今回追加：直近単価日付（F_開始日） */
				        "直近単価日付",
				            VAR k =
				                TRIM ( SUBSTITUTE ( [F_納入品目番号], UNICHAR ( 12288 ), " " ) )
				            VAR tLatest =
				                TOPN (
				                    1,
				                    FILTER (
				                        ALL ( 'TB_納入品目仕入先単価情報' ),
				                        TRIM ( SUBSTITUTE ( 'TB_納入品目仕入先単価情報'[F_納入品目番号], UNICHAR ( 12288 ), " " ) ) = k
				                            && NOT ISBLANK ( 'TB_納入品目仕入先単価情報'[F_開始日] )
				                    ),
				                    'TB_納入品目仕入先単価情報'[F_開始日], DESC
				                )
				            RETURN
				                MAXX ( tLatest, 'TB_納入品目仕入先単価情報'[F_開始日] )
				    )
				
				/* Step2：在庫金額＋仕入先略称 */
				VAR __Step2 =
				    ADDCOLUMNS (
				        __Step1,
				
				        "在庫金額",
				            VAR qty = [F_合計在庫数]
				            VAR price = [F_契約単価]
				            RETURN
				                IF ( ISBLANK ( qty ) || ISBLANK ( price ), BLANK (), qty * price ),
				
				        "F_仕入先略称",
				            LOOKUPVALUE (
				                'TB_仕入先情報'[F_仕入先略称],
				                'TB_仕入先情報'[F_仕入先番号], [R_仕入先番号]
				            )
				    )
				
				RETURN
				    __Step2
				
				```

	annotation PBI_Id = ce5fddc572fd42caa45ff93e3aeb323b

